generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  username      String?  @unique
  bio           String?
  avatarUrl     String?
  socialImage   String?
  theme         String   @default("default")
  accentColor   String   @default("#6366f1")
  showBranding    Boolean  @default(true)
  buttonStyle     String   @default("rounded")
  bioAlignment    String   @default("center")
  buttonTextColor String?
  backgroundColor String?
  avatarShape     String   @default("circle")
  fontFamily      String   @default("modern")
  fontSize        String   @default("md")
  linkBorderWidth String   @default("none")
  linkShadow      String   @default("none")
  linkSpacing     String   @default("normal")
  layoutMode      String   @default("list")
  hoverEffect     String   @default("lift")
  showAvatar      Boolean  @default(true)
  showBio         Boolean  @default(true)
  headerImageUrl  String?
  customCss       String?
  isLocked        Boolean  @default(false)
  pagePassword    String?
  buttonBorderColor String?
  buttonFontWeight String  @default("medium")
  countdownTitle  String?
  countdownDate   DateTime?
  enableEmailCapture Boolean @default(false)
  emailCaptureTitle String?
  metaTitle       String?
  metaDescription String?
  ogImageUrl      String?
  tipEnabled      Boolean  @default(false)
  tipVenmo        String?
  tipPayPal       String?
  tipCashApp      String?
  dashboardTourDone Boolean @default(false)
  customDomain    String?  @unique
  domainVerified Boolean @default(false)
  stripeCustomerId String?
  referralCode     String?  @unique
  referralCount    Int      @default(0)
  referredById  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  showInstagramGrid Boolean @default(false)
  gridColumns       Int     @default(2)

  referredBy   User?  @relation("Referrals", fields: [referredById], references: [id])
  referrals    User[] @relation("Referrals")
  accounts     Account[]
  sessions     Session[]
  links        Link[]
  socialLinks  SocialLink[]
  subscription Subscription?
  subscribers   Subscriber[]
  products      Product[]
  embeds        Embed[]
  pages         Page[]
  integrations  Integration[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Link {
  id          String    @id @default(cuid())
  userId      String
  title       String
  url         String
  icon        String?
  imageUrl    String?
  section     String?
  isActive    Boolean   @default(true)
  order       Int       @default(0)
  clicks      Int       @default(0)
  startsAt    DateTime?
  expiresAt   DateTime?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  gateType    String?   // subscribe, code, none
  gateValue   String?   // the code for code-lock
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  pageId      String?

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  clickLogs ClickLog[]
  page      Page?      @relation(fields: [pageId], references: [id])
}

model ClickLog {
  id        String   @id @default(cuid())
  linkId    String
  timestamp DateTime @default(now())
  referrer  String?
  userAgent String?

  link Link @relation(fields: [linkId], references: [id], onDelete: Cascade)
}

model SocialLink {
  id        String   @id @default(cuid())
  userId    String
  platform  String
  handle    String
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
}

model Subscription {
  id            String   @id @default(cuid())
  userId        String   @unique
  stripeId      String   @unique
  stripePriceId String?
  status        String   @default("inactive")
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscriber {
  id        String   @id @default(cuid())
  userId    String
  email     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
}

model Product {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  price       Int      // in cents
  fileUrl     String?
  fileType    String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  sold        Int      @default(0)
  stripePriceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sales ProductSale[]
}

model ProductSale {
  id              String   @id @default(cuid())
  productId       String
  buyerEmail      String?
  amount          Int
  status          String   @default("completed")
  stripePaymentId String?
  createdAt       DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Embed {
  id        String   @id @default(cuid())
  userId    String
  type      String   // youtube, spotify, soundcloud, podcast, tiktok, apple_music
  title     String?
  url       String
  embedUrl  String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Page {
  id        String   @id @default(cuid())
  userId    String
  title     String
  slug      String
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  links Link[]

  @@unique([userId, slug])
}

model Integration {
  id        String   @id @default(cuid())
  userId    String
  provider  String   // google_analytics, meta_pixel, tiktok_pixel, mailchimp, convertkit, kit
  key       String?
  value     String?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}
